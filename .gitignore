.DS_Store

# Kubeconfig is written to ~/.kube/mac_lab by default (outside the repo), but
# ignore any copy that lands here.
kubeconfig
*.kubeconfig

# Helm dependency artifacts — ArgoCD's repo-server builds these itself; never commit.
apps/**/charts/
apps/**/Chart.lock

# Bootstrap secrets applied out-of-band (SSH deploy key + ArgoCD repo Secret).
# NEVER commit — contains a private key. See specs/plan.md.
secrets/
